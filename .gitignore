#
# Pi-Menu .gitignore
# Never commit these files!
#

# Environment variables with secrets
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Recipe cache
data/recipes_cache/

# Per-household runtime data (seeded/generated locally, not source-controlled)
data/households/

# User-submitted feedback (contains real emails - not for the public repo)
data/feedback.json

# Local-dev self-signed TLS cert/key (not used by Railway, never belonged in
# a public repo - was tracked since the original Raspberry Pi setup)
deployment/cert.pem
deployment/key.pem

# Virtual environments
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log

# Data files
data/recipes_cache/
data/token_cache.json
*.db
*.db-journal
*.sqlite

# Temporary files
*.tmp
*.temp
.cache/

# Fresh chat startup helpers (local reference, not for git)
FRESH_CHAT_STARTUP.txt
new_chat_fresh_menu_planner.md


# OS
Thumbs.db
.DS_Store

# Playwright
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
e2e/.auth/
e2e_test.db
