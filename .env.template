# Pi-Menu Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit the .env file with real credentials!

# ============================================================================
# AZURE CONFIGURATION (Optional - for Microsoft To Do sync)
# ============================================================================
# Get these from https://portal.azure.com/
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_USERNAME=

# ============================================================================
# EMAIL CONFIGURATION (Optional - for email notifications)
# ============================================================================
EMAIL_SENDER=noreply@pi-menu.local
EMAIL_RECIPIENTS=your-email@example.com
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SEND_ENABLED=false

# ============================================================================
# HOUSEHOLD CONFIGURATION
# ============================================================================
# Replace this with your family/household name
HOUSEHOLD_NAME=My Family

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================
FLASK_ENV=production
FLASK_DEBUG=false
FLASK_SECRET_KEY=your-secret-key-change-this

# ============================================================================
# SCHEDULER CONFIGURATION
# ============================================================================
SCHEDULER_ENABLED=true
SCHEDULER_DAY=saturday
SCHEDULER_HOUR=9
SCHEDULER_MINUTE=0

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
