# Pi-Menu Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit the .env file with real credentials!

# ============================================================================
# TASK MANAGER INTEGRATIONS (Optional)
# ============================================================================

# Microsoft To Do - Uses OAuth flow (requires Azure app registration)
# Setup guide: Read docs/INTEGRATION_SETUP_GUIDE.md section "Microsoft To Do"
# Get these from: https://portal.azure.com/ → App registrations → New registration
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI=http://localhost:5001/callback

# Todoist - Get token from https://todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=

# TickTick - Get token from https://ticktick.com/user/myprofile
TICKTICK_API_TOKEN=

# Any.do - Get token from https://www.any.do/en/settings/account
ANYDO_API_TOKEN=

# Trello - Get API key and token from https://trello.com/app-key
TRELLO_API_KEY=
TRELLO_API_TOKEN=

# Notion - Create integration at https://www.notion.so/my-integrations
NOTION_API_TOKEN=
NOTION_DATABASE_ID=

# Google Keep - Find your Keep email in Gmail forwarding settings
GOOGLE_KEEP_EMAIL=

# ============================================================================
# EMAIL CONFIGURATION (Optional - for email notifications)
# ============================================================================
EMAIL_SENDER=noreply@your.email.local
EMAIL_RECIPIENTS=your-email@example.com
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SEND_ENABLED=false

# ============================================================================
# HOUSEHOLD CONFIGURATION
# ============================================================================
# Replace this with your family/household name
HOUSEHOLD_NAME=My Family

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================
FLASK_ENV=production
FLASK_DEBUG=false
FLASK_SECRET_KEY=your-secret-key-change-this

# ============================================================================
# SCHEDULER CONFIGURATION
# ============================================================================
SCHEDULER_ENABLED=true
SCHEDULER_DAY=saturday
SCHEDULER_HOUR=9
SCHEDULER_MINUTE=0

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
