# Pi-Menu Pi-Deployment Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# AZURE CONFIGURATION (Optional - for To Do sync)
# ============================================================================
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ============================================================================
# EMAIL CONFIGURATION (Optional)
# ============================================================================
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_RECIPIENTS=your-email@example.com
EMAIL_SEND_ENABLED=false

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================
FLASK_ENV=production
FLASK_DEBUG=false

# ============================================================================
# SCHEDULER CONFIGURATION
# ============================================================================
SCHEDULER_ENABLED=true
SCHEDULER_DAY=saturday
SCHEDULER_HOUR=9
SCHEDULER_MINUTE=0

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
