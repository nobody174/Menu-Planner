#
# Menu-Planner Environment Variables
# Copy this to .env and fill in your actual values
# Never commit .env to git!
#

# ── Flask Configuration ──────────────────────────────────────────────────────

FLASK_ENV=development
FLASK_DEBUG=false
FLASK_SECRET_KEY=your-secret-key-here-change-this

# ── Database Configuration ───────────────────────────────────────────────────

# For local development (SQLite):
# DATABASE_URL=sqlite:///menu_planner.db

# For PostgreSQL (Railway or local):
# DATABASE_URL=postgresql://user:password@localhost:5432/menu_planner_dev

# ── Household/Organization ──────────────────────────────────────────────────

HOUSEHOLD_NAME=My Family

# ── Azure / Microsoft Graph API (Optional) ──────────────────────────────────

# Only needed if you want Microsoft/Office 365 login integration
# AZURE_CLIENT_SECRET=your_secret_here_paste_it
# AZURE_CLIENT_ID=your_client_id_here
# AZURE_TENANT_ID=your_tenant_id_here
# AZURE_REDIRECT_URI=http://localhost:5000/callback

# ── Email Configuration (optional) ──────────────────────────────────────────

# EMAIL_USERNAME=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password
# EMAIL_SEND_ENABLED=false

# ── Local-only feature flags (optional) ──────────────────────────────────────
# Hidden, in-progress features. Leave commented out / unset for a normal
# public-matching local build. See docs/FEATURE_FLAGS.md for details.
# Never set any of these in production.

# FEATURE_DESSERTS_DRINKS=true
# FEATURE_SIDE_STASH=true
# FEATURE_DESSERT_PLANNER=true
