        "en": "Danish Pan-Fried Meat Patties"
      },
      "subtitle": {
        "no": "Danske møre kjøttkaker stekt i smør",
        "en": "Tender Danish meat patties fried in butter"
      },
      "difficulty": "easy",
      "cookTimeMinutes": 30,
      "servings": 4,
      "category": "Ground Meat & Sausages",
      "tags": [
        "traditional",
        "nordic",
        "comfort-food",
        "quick",
        "cuisine:nordic"
      ],
      "allergens": [
        "dairy",
        "egg",
        "gluten"
      ],
      "ingredients": [
        {
          "name": {
            "no": "Kjøttdeig (svin og kjøtt)",
            "en": "Ground meat (pork and beef)"
          },
          "amount": 500,
          "unit": {
            "no": "gram",
            "en": "g"
          }
        },
        {
          "name": {
            "no": "Løk, finrevet",
            "en": "Onion, finely grated"
          },
          "amount": 1,
          "unit": {
            "no": "stk",
            "en": "pcs"
          }
        },
        {
          "name": {
            "no": "Hvetemel",
            "en": "Wheat flour"
          },
          "amount": 3,
          "unit": {
            "no": "ss",
            "en": "tbsp"
          }
        },
        {
          "name": {
            "no": "Melk",
            "en": "Milk"
          },
          "amount": 150,
          "unit": {
            "no": "ml",
            "en": "ml"
          }
        },
        {
          "name": {
            "no": "Egg",
            "en": "Egg"
          },
          "amount": 1,
          "unit": {
            "no": "stk",
            "en": "pcs"
          }
        },
        {
          "name": {
            "no": "Smør til steking",
            "en": "Butter for frying"
          },
          "amount": 3,
          "unit": {
            "no": "ss",
            "en": "tbsp"
          }
        }
      ],
      "instructions": {
        "no": [
          "1. Rør sammen kjøttdeig, mel og egg til en jevn farse.",
          "2. Tilsett melk gradvis mens du rører, til farsen blir luftig og smidig.",
          "3. Bland inn revet løk, salt og pepper.",
          "4. La farsen trekke kaldt i kjøleskap i 15-20 minutter.",
          "5. Form ovale kaker med en skje dyppet i vann.",
          "6. Stek frikadellene i smør på middels varme i 4-5 minutter på hver side til de er gyldne og gjennomstekt.",
          "7. Server med kokte poteter og brun eller hvit sjysås."
        ],
        "en": [
          "1. Mix the ground meat, flour and egg into a smooth batter.",
          "2. Gradually add the milk while stirring until the mixture becomes light and pliable.",
          "3. Fold in the grated onion, salt and pepper.",
          "4. Let the mixture rest in the fridge for 15-20 minutes.",
          "5. Shape oval patties using a spoon dipped in water.",
          "6. Fry the patties in butter over medium heat for 4-5 minutes per side until golden and cooked through.",
          "7. Serve with boiled potatoes and brown or white gravy."
        ]
      }
    },
