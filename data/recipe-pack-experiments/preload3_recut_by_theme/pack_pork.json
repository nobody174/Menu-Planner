    {
      "id": "hol_013",
      "title": {
        "no": "Juleskinke",
        "en": "Christmas Ham"
      },
      "subtitle": {
        "no": "Saltet og glasert juleskinke, en norsk juletradisjon",
        "en": "Cured and glazed Christmas ham, a Norwegian holiday tradition"
      },
      "difficulty": "medium",
