    {
      "id": "nd_029",
      "title": {
        "no": "Raspeballer",
        "en": "Norwegian Potato Dumplings"
      },
      "subtitle": {
        "no": "Potetraspeballer kokt med saltet flesk",
        "en": "Grated potato dumplings boiled with salted pork"
      },
      "difficulty": "medium",
      "cookTimeMinutes": 90,
      "servings": 4,
      "category": "Pork",
      "tags": [
        "traditional",
        "nordic",
        "comfort-food",
        "cuisine:nordic"
      ],
      "allergens": [],
      "ingredients": [
        {
          "name": {
