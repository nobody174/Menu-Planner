        },
        {
          "name": {"no": "Smør", "en": "Butter"},
          "amount": 200,
          "unit": {"no": "gram", "en": "g"}
        },
        {
          "name": {"no": "Rosiner", "en": "Raisins"},
          "amount": 300,
          "unit": {"no": "gram", "en": "g"}
