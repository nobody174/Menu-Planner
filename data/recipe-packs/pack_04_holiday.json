          "amount": 50,
          "unit": {"no": "gram", "en": "g"}
        },
        {
          "name": {"no": "Salt", "en": "Salt"},
          "amount": 1,
          "unit": {"no": "ts", "en": "tsp"}
        },
        {
          "name": {"no": "Vaniljeekstrakt", "en": "Vanilla extract"},
          "amount": 1,
          "unit": {"no": "ts", "en": "tsp"}
        },
        {
          "name": {"no": "Mandler (hakket)", "en": "Almonds (chopped)"},
          "amount": 50,
