    {
      "id": "hol_008",
      "title": {
        "no": "Nyårsaften: Flott Stekt Oksebiff",
        "en": "New Year's Eve: Beautiful Roasted Beef"
      },
      "subtitle": {
        "no": "Elegant New Year's dinner",
        "en": "Elegant New Year's dinner"
      },
      "difficulty": "hard",
      "cookTimeMinutes": 90,
      "servings": 6,
      "category": "Meat",
      "tags": ["newyear", "beef", "elegant", "festive"],
      "allergens": [],
      "ingredients": [
        {
          "name": {"no": "Oksebiff (beste kutt)", "en": "Beef roast (best cut)"},
          "amount": 1500,
          "unit": {"no": "gram", "en": "g"}
        },
        {
          "name": {"no": "Smør", "en": "Butter"},
          "amount": 100,
          "unit": {"no": "gram", "en": "g"}
        },
        {
          "name": {"no": "Hvitløk", "en": "Garlic"},
          "amount": 4,
          "unit": {"no": "fedd", "en": "cloves"}
        },
        {
          "name": {"no": "Rosmarin (frisk)", "en": "Rosemary (fresh)"},
          "amount": 3,
          "unit": {"no": "stengel", "en": "sprigs"}
        },
        {
          "name": {"no": "Salt og pepper", "en": "Salt and pepper"},
          "amount": 1,
          "unit": {"no": "etter smak", "en": "to taste"}
        },
        {
          "name": {"no": "Rødvin", "en": "Red wine"},
          "amount": 200,
          "unit": {"no": "ml", "en": "ml"}
        },
        {
          "name": {"no": "Buljong (okse)", "en": "Beef broth"},
          "amount": 250,
          "unit": {"no": "ml", "en": "ml"}
        }
      ],
      "instructions": {
        "no": [
          "1. Ta kjøttet ut av kjøleskapet 1 time før tilberedelse.",
          "2. Salt og pepper det godt.",
          "3. Heat smør i en stor gryte på høy varme.",
          "4. Brun kjøttet på alle sider.",
          "5. Fjern kjøttet og steik hvitløk og rosmarin.",
          "6. Hell på rødvin og buljong.",
          "7. Tilbakesett kjøttet og dekk.",
          "8. Bak på 160°C i ca. 45-60 minutter for medium-rare.",
          "9. La kjøttet hvile i 15 minutter.",
          "10. Server med sprøllet hull, grønnsaker og saus fra pannen."
        ],
        "en": [
          "1. Remove meat from refrigerator 1 hour before cooking.",
          "2. Salt and pepper it well.",
          "3. Heat butter in a large pot on high heat.",
          "4. Brown meat on all sides.",
          "5. Remove meat and fry garlic and rosemary.",
          "6. Pour in red wine and broth.",
          "7. Return meat and cover.",
          "8. Bake at 160°C for about 45-60 minutes for medium-rare.",
          "9. Let meat rest 15 minutes.",
          "10. Serve with roasted vegetables and gravy from pan."
        ]
      }
    },
