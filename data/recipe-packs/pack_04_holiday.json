      "id": "hol_012",
      "title": {
        "no": "Julebakst: Gingerbread House",
        "en": "Christmas Baking: Gingerbread House"
      },
      "subtitle": {
        "no": "Tradisjonell leikateklubb",
        "en": "Traditional gingerbread house"
      },
      "difficulty": "hard",
      "cookTimeMinutes": 240,
      "servings": 8,
      "category": "Other",
      "tags": ["christmas", "gingerbread", "building", "festive"],
      "allergens": ["gluten", "dairy", "eggs"],
      "ingredients": [
        {
          "name": {"no": "Hvetemel", "en": "Wheat flour"},
          "amount": 500,
          "unit": {"no": "gram", "en": "g"}
        },
        {
          "name": {"no": "Smør", "en": "Butter"},
          "amount": 200,
          "unit": {"no": "gram", "en": "g"}
        },
        {
          "name": {"no": "Brunsukkert", "en": "Brown sugar"},
          "amount": 200,
          "unit": {"no": "gram", "en": "g"}
        },
        {
          "name": {"no": "Egg", "en": "Eggs"},
          "amount": 2,
          "unit": {"no": "stk", "en": "pieces"}
        },
        {
          "name": {"no": "Ingefær (malt)", "en": "Ginger (ground)"},
          "amount": 2,
          "unit": {"no": "ts", "en": "tsp"}
        },
        {
          "name": {"no": "Kanel", "en": "Cinnamon"},
          "amount": 2,
          "unit": {"no": "ts", "en": "tsp"}
        },
        {
