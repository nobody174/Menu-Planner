        },
        {
          "name": {"no": "Kanelstang (pulver)", "en": "Cinnamon (powder)"},
          "amount": 1,
          "unit": {"no": "ts", "en": "tsp"}
        },
        {
          "name": {"no": "Pepper (sort, malt)", "en": "Black pepper (ground)"},
