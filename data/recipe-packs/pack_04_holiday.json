    {
      "id": "hol_010",
      "title": {
        "no": "Dessert: Sjokolade Mousse",
        "en": "Dessert: Chocolate Mousse"
      },
      "subtitle": {
        "no": "Elegant og lys sjokolade-mousse",
        "en": "Elegant light chocolate mousse"
      },
      "difficulty": "easy",
      "cookTimeMinutes": 30,
      "servings": 4,
      "category": "Other",
      "tags": ["dessert", "chocolate", "elegant", "holiday"],
      "allergens": ["dairy", "eggs"],
      "ingredients": [
        {
          "name": {"no": "Sjokolade (mørk)", "en": "Chocolate (dark)"},
          "amount": 200,
          "unit": {"no": "gram", "en": "g"}
        },
        {
          "name": {"no": "Egg (eller pasteurisert)", "en": "Eggs (or pasteurized)"},
          "amount": 4,
          "unit": {"no": "stk", "en": "pieces"}
        },
        {
          "name": {"no": "Fløte (tykk)", "en": "Cream (heavy)"},
          "amount": 300,
          "unit": {"no": "ml", "en": "ml"}
        },
        {
          "name": {"no": "Sukker", "en": "Sugar"},
          "amount": 50,
          "unit": {"no": "gram", "en": "g"}
        },
        {
          "name": {"no": "Kaffe (svak)", "en": "Coffee (strong)"},
          "amount": 2,
          "unit": {"no": "ss", "en": "tbsp"}
        },
        {
          "name": {"no": "Vaniljeekstrakt", "en": "Vanilla extract"},
          "amount": 1,
          "unit": {"no": "ts", "en": "tsp"}
        }
      ],
      "instructions": {
        "no": [
          "1. Smelt sjokoladen i en bolle over dampbad.",
          "2. Del egg: eggeplommer i en bolle, egg-hviter i en annen.",
          "3. Visp eggeplommer med sukker til det er kremete.",
          "4. Fold in smeltet sjokolade.",
          "5. Tilsett kaffe og vaniljeekstrakt.",
          "6. Visp egg-hviter stivt og fold forsiktig inn.",
          "7. Visp fløten stivt og fold forsiktig inn.",
          "8. Fordel i glass eller skåler.",
          "9. Kjøl minst 2 timer.",
          "10. Server med kakaopulver eller sjokoladeflak."
        ],
        "en": [
          "1. Melt chocolate in a bowl over double boiler.",
          "2. Separate eggs: yolks in one bowl, whites in another.",
          "3. Whisk yolks with sugar until creamy.",
          "4. Fold in melted chocolate.",
          "5. Add coffee and vanilla extract.",
          "6. Beat egg whites stiff and fold in carefully.",
          "7. Whip cream stiff and fold in carefully.",
          "8. Divide into glasses or bowls.",
          "9. Chill at least 2 hours.",
          "10. Serve with cocoa powder or chocolate flakes."
        ]
      }
    },
