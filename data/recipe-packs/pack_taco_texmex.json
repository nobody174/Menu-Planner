      ],
      "instructions": {
        "no": [
          "1. Finhakk løk og hvitløk.",
          "2. Brun kjøttdeigen i en panne på middels-høy varme.",
          "3. Tilsett løk og hvitløk, stek til løken er blank.",
          "4. Krydre med spisskummen, paprikapulver og chilipulver.",
          "5. Rør og stek i 2-3 minutter til.",
          "6. Varm tortillaene i en tørr panne eller i ovnen.",
          "7. Kutt tomat og salat, riv osten.",
          "8. Sett sammen tacoene med kjøttdeig og toppinger etter ønske."
        ],
        "en": [
          "1. Finely chop onion and garlic.",
          "2. Brown the ground beef in a pan over medium-high heat.",
          "3. Add onion and garlic, cook until the onion is translucent.",
          "4. Season with cumin, paprika powder and chili powder.",
          "5. Stir and cook for 2-3 more minutes.",
          "6. Warm the tortillas in a dry pan or in the oven.",
          "7. Dice the tomato and lettuce, grate the cheese.",
          "8. Assemble the tacos with the beef and your choice of toppings."
        ]
      }
