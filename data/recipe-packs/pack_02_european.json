    {
      "id": "eu_012",
      "title": {
        "no": "Crème Brûlée",
        "en": "Crème Brûlée"
      },
      "subtitle": {
        "no": "Fransk kullglassert fløte-dessert",
        "en": "French caramelized cream dessert"
      },
      "difficulty": "medium",
      "cookTimeMinutes": 90,
      "servings": 4,
      "category": "Other",
      "tags": ["french", "dessert", "elegant", "creamy"],
      "allergens": ["dairy", "eggs"],
      "ingredients": [
        {
          "name": {"no": "Fløte (tykk)", "en": "Cream (heavy)"},
          "amount": 400,
          "unit": {"no": "ml", "en": "ml"}
        },
        {
          "name": {"no": "Melk", "en": "Milk"},
          "amount": 100,
          "unit": {"no": "ml", "en": "ml"}
        },
        {
          "name": {"no": "Eggeplommer", "en": "Egg yolks"},
          "amount": 5,
          "unit": {"no": "stk", "en": "pieces"}
        },
        {
          "name": {"no": "Sukker (hvitt)", "en": "Sugar (white)"},
          "amount": 100,
          "unit": {"no": "gram", "en": "g"}
        },
        {
          "name": {"no": "Vaniljeekstrakt", "en": "Vanilla extract"},
          "amount": 1,
          "unit": {"no": "ts", "en": "tsp"}
        },
        {
          "name": {"no": "Sukker (til crusting)", "en": "Sugar (for crusting)"},
          "amount": 4,
          "unit": {"no": "ts", "en": "tsp"}
        }
      ],
      "instructions": {
        "no": [
          "1. Heat fløten og melk til det er varmt men ikke kokende.",
          "2. Visp eggeplommer med sukker til det er lett og gult.",
          "3. Hell fløten langsomt i eggeplommen mens du rører konstant.",
          "4. Tilsett vaniljeekstrakt.",
          "5. Sil blandingen gjennom en fin sil.",
          "6. Hell i små ramekiner eller kopjer.",
          "7. Stelle them i et vannbad på 160°C i 25-30 minutter.",
          "8. Kjøl i minst 4 timer.",
          "9. Rett før servering, sprinkle sukker på toppen og kullglasér med en brenner."
        ],
        "en": [
          "1. Heat cream and milk until warm but not boiling.",
          "2. Whisk egg yolks with sugar until light and pale.",
          "3. Slowly pour cream into yolks while stirring constantly.",
          "4. Add vanilla extract.",
          "5. Strain mixture through a fine sieve.",
          "6. Pour into small ramekins or cups.",
          "7. Bake in a water bath at 160°C for 25-30 minutes.",
          "8. Chill for at least 4 hours.",
          "9. Just before serving, sprinkle sugar on top and caramelize with a torch."
        ]
      }
