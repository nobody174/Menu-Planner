    {
      "id": "no_017",
      "title": {
        "no": "Pølse med Lompe",
        "en": "Sausage with Potato Flatbread"
      },
      "subtitle": {
        "no": "Norsk gatemat med varm pølse rullet i potetlompe",
        "en": "Norwegian street food with a hot sausage wrapped in potato flatbread"
      },
      "difficulty": "easy",
      "cookTimeMinutes": 40,
      "servings": 4,
      "category": "Sides & Light Meals",
      "tags": [
        "traditional",
        "norwegian",
        "quick",
        "street-food",
        "cuisine:norwegian"
      ],
      "allergens": [
        "gluten"
      ],
      "ingredients": [
        {
          "name": {
            "no": "Potet (kokt og moset)",
            "en": "Potatoes (boiled and mashed)"
          },
          "amount": 600,
          "unit": {
            "no": "gram",
            "en": "g"
          }
        },
        {
          "name": {
            "no": "Mel",
            "en": "Flour"
          },
          "amount": 150,
          "unit": {
            "no": "gram",
            "en": "g"
          }
        },
        {
          "name": {
            "no": "Salt",
            "en": "Salt"
          },
          "amount": 1,
          "unit": {
            "no": "teskje",
            "en": "teaspoon"
          }
        },
        {
          "name": {
            "no": "Grillpølser",
            "en": "Grilling sausages"
          },
          "amount": 8,
          "unit": {
            "no": "stk",
            "en": "pieces"
          }
        },
        {
          "name": {
            "no": "Ketsjup",
            "en": "Ketchup"
          },
          "amount": 4,
          "unit": {
            "no": "spiseskjeer",
            "en": "tablespoons"
          }
        },
        {
          "name": {
            "no": "Sennep",
            "en": "Mustard"
          },
          "amount": 4,
          "unit": {
            "no": "spiseskjeer",
            "en": "tablespoons"
          }
        },
        {
          "name": {
            "no": "Stekt løk",
            "en": "Fried onion bits"
          },
          "amount": 4,
          "unit": {
            "no": "spiseskjeer",
            "en": "tablespoons"
          }
        }
      ],
      "instructions": {
        "no": [
          "1. Kok potetene møre, mos dem godt og la avkjøles litt.",
          "2. Bland inn mel og salt til en jevn deig.",
          "3. Del deigen i emner og kjevle hvert emne tynt ut til en rund flatbrødform.",
          "4. Stek lompene på tørr, varm stekepanne eller takke til de får lyse, gylne flekker på begge sider.",
          "5. Kok eller grill pølsene til de er gjennomvarme.",
          "6. Legg en pølse i hver lompe og topp med ketsjup, sennep og stekt løk.",
          "7. Rull sammen og server umiddelbart."
        ],
        "en": [
          "1. Boil the potatoes until tender, mash well, and let cool slightly.",
          "2. Mix in flour and salt to form a smooth dough.",
          "3. Divide the dough into portions and roll each one out thin into a round flatbread shape.",
          "4. Cook the flatbreads on a dry, hot griddle or pan until lightly golden on both sides.",
          "5. Boil or grill the sausages until heated through.",
          "6. Place a sausage in each flatbread and top with ketchup, mustard, and fried onion bits.",
          "7. Roll up and serve immediately."
        ]
      }
    },
