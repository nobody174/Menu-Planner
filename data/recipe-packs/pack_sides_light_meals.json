          "name": {
            "no": "Salt og pepper",
            "en": "Salt and pepper"
          },
          "amount": 1,
          "unit": {
            "no": "after taste",
            "en": "to taste"
          }
        }
      ],
      "instructions": {
        "no": [
          "1. Koke poteter til møre",
          "2. Brun pølsene i olje i en stekepanne",
          "3. Hakk løk, steke i samme panne til myk",
          "4. Strø mel over løken, rør godt",
